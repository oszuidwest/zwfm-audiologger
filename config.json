{
  "recordings_dir": "/var/audio",
  "port": 8080,
  "keep_days": 31,
  "timezone": "Europe/Amsterdam",
  "alerting": {
    "webhook_url": "https://hooks.example.com/alerts",
    "email": {
      "enabled": false,
      "smtp_host": "smtp.example.com",
      "smtp_port": 587,
      "smtp_user": "alerts@example.com",
      "smtp_pass": "your-smtp-password",
      "from": "alerts@example.com",
      "to": ["admin@example.com"]
    },
    "disk_threshold_percent": 10,
    "incomplete_threshold_seconds": 3000
  },
  "stations": {
    "zuidwest": {
      "stream_url": "https://icecast.zuidwest.cloud/zuidwest.mp3",
      "metadata_url": "https://www.zuidwestupdate.nl/wp-json/zw/v1/broadcast_data",
      "metadata_path": "fm.now",
      "parse_metadata": true
    },
    "rucphen": {
      "stream_url": "https://icecast.zuidwest.cloud/radiorucphen.aac",
      "metadata_url": "https://rucphen.zuidwest.cloud/proxy.php",
      "metadata_path": "fm.now",
      "parse_metadata": true
    }
  }
}
